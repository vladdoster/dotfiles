[submodule "osx-setup"]
    path = share/.local/share/osx-setup
    url = https://github.com/vladdoster/osx-setup.git
    branch = master
[submodule "oh-my-zsh"]
    path = share/.local/share/ohmyzsh
    url = https://github.com/vladdoster/oh-my-zsh.git
    branch = master
[submodule "neovim-configuration"]
    path = nvim/.config/nvim
    url = https://github.com/vladdoster/neovim-configuration
    branch = master
[submodule "hammerspoon-asm"]
    path = share/.local/share/hammerspoon-asm
    url = https://github.com/vladdoster/hammerspoon_asm
    branch = master
[submodule "hammerspoon-asm.axuielement"]
	path = share/.local/share/hammerspoon-axuielement
	url = https://github.com/asmagill/hs._asm.axuielement
	branch = master
